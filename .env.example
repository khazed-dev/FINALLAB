PORT=3000
NODE_ENV=production
APP_NAME=Security Operations Mini Dashboard

DASHBOARD_USER=admin
DASHBOARD_PASS=change-this-password
SESSION_SECRET=change-this-session-secret
SESSION_TTL_HOURS=12
COOKIE_SECURE=false

METRICS_INTERVAL_MS=1000
METRICS_HISTORY_LIMIT=120

NGINX_STATUS_URL=http://127.0.0.1/nginx_status
NGINX_ACCESS_LOG_PATH=/var/log/nginx/security_dashboard_access.log
NETWORK_INTERFACE=

DEFENSE_STATE_FILE=./config/runtime/defense-state.json
NGINX_DEFENSE_SNIPPET_PATH=/etc/nginx/snippets/security-dashboard-defense.conf
NGINX_RATE_ZONE_PATH=/etc/nginx/conf.d/security-dashboard-rate-zone.conf
NGINX_CONN_ZONE_PATH=/etc/nginx/conf.d/security-dashboard-conn-zone.conf
NGINX_EMERGENCY_PAGE_PATH=/var/www/html/security-dashboard-emergency.html
NGINX_TEST_COMMAND=sudo nginx -t
NGINX_RELOAD_COMMAND=sudo systemctl reload nginx

RATE_LIMIT_ZONE_NAME=soc_ratelimit
RATE_LIMIT_RPS=15r/s
RATE_LIMIT_BURST=25
RATE_LIMIT_STATUS=429

CONN_LIMIT_ZONE_NAME=soc_connlimit
CONN_LIMIT_PER_IP=30

EMERGENCY_RATE_LIMIT_RPS=5r/s
EMERGENCY_RATE_LIMIT_BURST=5
EMERGENCY_CONN_LIMIT_PER_IP=8
EMERGENCY_STATUS_CODE=503
